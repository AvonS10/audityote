# ============================================================
# ControlMap — environment variables (COMMITTED TEMPLATE)
# Copy to `.env` and fill in real values. NEVER commit `.env`.
#   cp .env.example .env
# ============================================================

# ---- PostgreSQL (the `db` container) ----
POSTGRES_DB=controlmap
POSTGRES_USER=controlmap
POSTGRES_PASSWORD=change-me-strong-db-password

# ---- Backend datasource ----
# Use this (localhost) when you run the backend FROM INTELLIJ against the
# dockerized Postgres. Inside docker-compose, the backend service overrides
# the host to `db:5432` automatically — see docker-compose.yml.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/controlmap
SPRING_DATASOURCE_USERNAME=controlmap
SPRING_DATASOURCE_PASSWORD=change-me-strong-db-password

# ---- Spring profile (dev | prod) ----
SPRING_PROFILES_ACTIVE=dev

# ---- Auth secret (Spring Security) ----
# Long random string. Generate one with:  openssl rand -base64 48
# If you choose stateless JWT (PLAN §16), this is your JWT signing key —
# rename to JWT_SECRET to match if you prefer.
APP_SESSION_SECRET=change-me-long-random-secret

# ---- CORS (dev only — the Vite dev server origin) ----
APP_CORS_ORIGINS=http://localhost:5173

# ---- Seed demo users (created on first run; NOT real credentials) ----
SEED_ANALYST_EMAIL=analyst@controlmap.local
SEED_ANALYST_PASSWORD=change-me-analyst
SEED_REVIEWER_EMAIL=reviewer@controlmap.local
SEED_REVIEWER_PASSWORD=change-me-reviewer

# ============================================================
# AI-assisted control mapping (STRETCH — off by default)
# Enable only when you build the feature (PLAN §14 S1–S3). The Anthropic API is
# billed SEPARATELY from any Claude.ai Pro/Max subscription (usage-based; prepaid
# credits from $5). Key is backend-only — never expose it to the frontend.
# ============================================================
AI_SUGGESTIONS_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Optional — only for the RAG upgrade (pgvector + embeddings). Anthropic has no
# embeddings model; Voyage AI is its recommended provider.
# VOYAGE_API_KEY=

# ============================================================
# DEPLOY ONLY (Week 4 — server + domain + TLS). Leave blank until then.
# ============================================================
# Your domain, e.g. controlmap.example.com
APP_DOMAIN=
# Email Let's Encrypt uses for cert notices (Caddy)
ACME_EMAIL=
